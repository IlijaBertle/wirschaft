---
import ClickSpark from '../components/ClickSpark';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "WIRschaft - Starke Wirtschaft. Gelebte Geschichte. Gemeinsame Events." } = Astro.props;
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/logo.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Google Fonts passend zu 'LogoWIRschaft gelb.png' -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Montserrat:wght@600;700;900&display=swap" rel="stylesheet">
	</head>
	<body>
		<!-- ClickSpark Effekt über die gesamte Applikation mit rotem CI-Funken -->
		<ClickSpark client:load sparkColor="#ff0000" sparkSize={10} sparkRadius={15} sparkCount={8} duration={400}>
			<div class="layout-wrapper">
				
				<!-- LIQUID GLASS HEADER MIT BRUTALIST BUTTONS -->
				<header class="site-header">
					<div class="header-container">
						<!-- Logo Links -->
						<a href="/" class="logo-link">
							<img src="/logo.png" alt="WIRschaft Logo" class="site-logo" />
						</a>

						<!-- Desktop Navigation mit haptischen Buttons -->
						<nav class="desktop-nav">
							<ul class="nav-list">
								<li><a href="/" class="layout-btn small-btn white-btn">Startseite</a></li>
								
								<!-- Dropdown: Über uns als Button -->
								<li class="dropdown">
									<button class="layout-btn small-btn white-btn dropdown-toggle" aria-expanded="false">
										Über uns 
										<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
									</button>
									<ul class="dropdown-menu">
										<li><a href="/ueber-uns/geschichte">Geschichte</a></li>
										<li><a href="/ueber-uns/wie-alles-begann">Wie alles begann</a></li>
										<li><a href="/ueber-uns/das-erste-jahr">Das erste Jahr</a></li>
										<li><a href="/ueber-uns/das-team">Das Team</a></li>
										<li><a href="/ueber-uns/philosophie">Unsere Philosophie</a></li>
									</ul>
								</li>
								
								<li><a href="/partner" class="layout-btn small-btn white-btn">Partner</a></li>
								<li><a href="/ags" class="layout-btn small-btn green-btn">AGs</a></li>
								<li><a href="/termine-kalender" class="layout-btn small-btn red-btn">Termine</a></li>
							</ul>
						</nav>

						<!-- Mobile Menu Button als runder Brutalist Button -->
						<button class="mobile-menu-toggle layout-btn round-btn white-btn" aria-label="Menü öffnen" aria-expanded="false">
							<span class="hamburger-box">
								<span class="hamburger-inner"></span>
							</span>
						</button>
					</div>
				</header>

				<!-- MOBILE NAVIGATION OVERLAY (Vollwertige große Klick-Buttons) -->
				<nav class="mobile-nav" id="mobileNav">
					<ul class="mobile-nav-list">
						<li><a href="/" class="layout-btn large-btn white-btn full-w">Startseite</a></li>
						
						<!-- Mobile Dropdown -->
						<li class="mobile-dropdown">
							<button class="layout-btn large-btn white-btn full-w mobile-dropdown-toggle">
								Über uns
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="m6 9 6 6 6-6"/></svg>
							</button>
							<ul class="mobile-dropdown-menu">
								<li><a href="/ueber-uns/geschichte">Geschichte</a></li>
								<li><a href="/ueber-uns/wie-alles-begann">Wie alles begann</a></li>
								<li><a href="/ueber-uns/das-erste-jahr">Das erste Jahr</a></li>
								<li><a href="/ueber-uns/das-team">Das Team</a></li>
								<li><a href="/ueber-uns/philosophie">Unsere Philosophie</a></li>
							</ul>
						</li>
						
						<li><a href="/partner" class="layout-btn large-btn white-btn full-w">Partner</a></li>
						<li><a href="/ags" class="layout-btn large-btn green-btn full-w">AGs</a></li>
						<li><a href="/termine-kalender" class="layout-btn large-btn red-btn full-w">Termine und Kalender</a></li>
					</ul>
				</nav>

				<!-- HAUPTINHALT -->
				<main class="main-content">
					<slot />
				</main>

				<!-- RETRO BRUTALIST FOOTER -->
				<footer class="site-footer">
					<div class="footer-container">
						<p class="footer-copy">
							&copy; {new Date().getFullYear()} <span class="f-red">WIR</span><span class="f-green">schaft</span>.
						</p>
						<div class="footer-links">
							<a href="/impressum" class="layout-btn mini-btn white-btn">Impressum</a>
							<a href="/datenschutzerklaerung" class="layout-btn mini-btn white-btn">Datenschutz</a>
						</div>
					</div>
				</footer>
				
			</div>
		</ClickSpark>

		<!-- Script für responsive Interaktionen -->
		<script>
			const menuToggle = document.querySelector('.mobile-menu-toggle');
			const mobileNav = document.getElementById('mobileNav');
			const mobileDropdownToggle = document.querySelector('.mobile-dropdown-toggle');
			const mobileDropdownMenu = document.querySelector('.mobile-dropdown-menu');

			// Hamburger Menu toggeln
			menuToggle?.addEventListener('click', () => {
				const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
				menuToggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
				mobileNav?.classList.toggle('is-active');
				document.body.classList.toggle('menu-open');
			});

			// Mobiles Untermenü aufklappen
			mobileDropdownToggle?.addEventListener('click', () => {
				mobileDropdownToggle.classList.toggle('is-open');
				mobileDropdownMenu?.classList.toggle('is-visible');
			});

			// Desktop-Dropdown Klick-Support (Aria-Accessibility)
			const desktopDropdown = document.querySelector('.desktop-nav .dropdown');
			const dropdownToggle = desktopDropdown?.querySelector('.dropdown-toggle');
			
			dropdownToggle?.addEventListener('click', (e) => {
				e.stopPropagation();
				const isExpanded = dropdownToggle.getAttribute('aria-expanded') === 'true';
				dropdownToggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
				desktopDropdown?.classList.toggle('is-open');
			});

			document.addEventListener('click', () => {
				if (desktopDropdown?.classList.contains('is-open')) {
					dropdownToggle?.setAttribute('aria-expanded', 'false');
					desktopDropdown.classList.remove('is-open');
				}
			});
		</script>
	</body>
</html>

<!-- GLOBALE STYLES -->
<style is:global>
	:root {
		/* Farbkonfiguration aus LogoWIRschaft gelb.png */
		--wirschaft-red: #ff0000;
		--wirschaft-green: #00b341;
		--black: #111111;
		--brutal-bg: #f6f3ec;
		--white: #ffffff;
		
		/* Fonts */
		--font-sans-bold: 'Montserrat', sans-serif;
		--font-script: 'Caveat', cursive;
		
		--header-height: 85px;

		/* LIQUID GLASS SPECIFICATIONS */
		--glass-bg: linear-gradient(135deg, rgba(255, 255, 255, 0.75) 0%, rgba(255, 255, 255, 0.4) 100%);
		--glass-blur: 24px;
		--glass-border: 1px solid rgba(255, 255, 255, 0.5);
		--glass-shadow: 
			0 2px 4px rgba(0, 0, 0, 0.01),
			0 10px 30px -10px rgba(17, 17, 17, 0.04);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html, body {
		height: 100%;
		font-family: var(--font-sans-bold);
		background-color: var(--brutal-bg);
		color: var(--black);
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
	}

	.layout-wrapper {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	/* LIQUID GLASS STICKY HEADER */
	.site-header {
		position: sticky;
		top: 0;
		left: 0;
		right: 0;
		height: var(--header-height);
		background: var(--glass-bg);
		
		/* Prisma-Effekt beim Scrollen */
		backdrop-filter: blur(var(--glass-blur)) saturate(190%);
		-webkit-backdrop-filter: blur(var(--glass-blur)) saturate(190%);
		
		border-bottom: var(--glass-border);
		z-index: 100;
		box-shadow: var(--glass-shadow);
	}

	.header-container {
		max-width: 1200px;
		height: 100%;
		margin: 0 auto;
		padding: 0 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo-link {
		display: flex;
		align-items: center;
		height: 100%;
	}

	.site-logo {
		height: 46px;
		width: auto;
		object-fit: contain;
	}

	/* DESKTOP NAV MENU */
	.desktop-nav {
		display: none;
	}

	.nav-list {
		display: flex;
		align-items: center;
		list-style: none;
		gap: 12px;
	}

	/* MASTER-BUTTON-STYLE FÜR DAS GANZE LAYOUT (Exakte Klickphysik) */
	.layout-btn {
		appearance: none;
		border: none;
		outline: none;
		cursor: pointer;
		font-family: var(--font-sans-bold);
		font-weight: 900;
		text-transform: uppercase;
		text-decoration: none;
		text-align: center;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		border: 2px solid var(--black);
		color: var(--black);
		transition: transform .1s ease, box-shadow .1s ease, background .1s ease;
	}

	/* Button-Größen */
	.small-btn {
		height: 42px;
		padding: 0 16px;
		font-size: 12px;
		border-radius: 12px;
		box-shadow: 0 4px 0 var(--black);
	}
	.small-btn:hover { transform: translateY(-1px); box-shadow: 0 5px 0 var(--black); }
	.small-btn:active { transform: translateY(4px); box-shadow: 0 0 0 var(--black); }

	.large-btn {
		height: 58px;
		padding: 0 24px;
		font-size: 15px;
		border-radius: 16px;
		box-shadow: 0 6px 0 var(--black);
	}
	.large-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 0 var(--black); }
	.large-btn:active { transform: translateY(6px); box-shadow: 0 0 0 var(--black); }

	.mini-btn {
		height: 34px;
		padding: 0 12px;
		font-size: 11px;
		border-radius: 8px;
		box-shadow: 0 3px 0 var(--black);
	}
	.mini-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 0 var(--black); }
	.mini-btn:active { transform: translateY(3px); box-shadow: 0 0 0 var(--black); }

	.round-btn {
		width: 44px;
		height: 44px;
		padding: 0;
		border-radius: 50%;
		box-shadow: 0 4px 0 var(--black);
	}
	.round-btn:hover { transform: translateY(-1px); box-shadow: 0 5px 0 var(--black); }
	.round-btn:active { transform: translateY(4px); box-shadow: 0 0 0 var(--black); }

	/* Button-Farben */
	.white-btn { background: var(--white); }
	.red-btn { background: var(--wirschaft-red); color: var(--white); }
	.red-btn:hover { filter: brightness(1.1); }
	.green-btn { background: var(--wirschaft-green); color: var(--white); }
	.green-btn:hover { filter: brightness(1.05); }
	
	.full-w { width: 100%; }

	/* LIQUID GLASS DROPDOWN (Über uns) */
	.dropdown {
		position: relative;
	}

	.dropdown-menu {
		position: absolute;
		top: calc(100% + 12px);
		left: 0;
		min-width: 240px;
		
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 255, 255, 0.85) 100%);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 2px solid var(--black);
		
		border-radius: 18px;
		box-shadow: 0 15px 30px -10px rgba(0,0,0,0.1);
		list-style: none;
		padding: 8px;
		opacity: 0;
		visibility: hidden;
		transform: translateY(10px);
		transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.dropdown:hover .dropdown-menu,
	.dropdown.is-open .dropdown-menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.dropdown-menu a {
		display: block;
		padding: 11px 16px;
		color: var(--black);
		text-decoration: none;
		font-size: 13px;
		font-weight: 700;
		border-radius: 10px;
		transition: all 0.15s ease;
	}

	.dropdown-menu a:hover {
		background-color: rgba(0, b3, 65, 0.08);
		color: var(--wirschaft-green);
		padding-left: 20px;
	}

	.dropdown-toggle svg {
		transition: transform 0.2s ease;
	}
	.dropdown:hover .dropdown-toggle svg,
	.dropdown.is-open .dropdown-toggle svg {
		transform: rotate(180deg);
	}

	/* MAIN CONTENT */
	.main-content {
		flex: 1 0 auto;
		width: 100%;
	}

	/* RETRO BRUTALIST FOOTER */
	.site-footer {
		background-color: var(--white);
		border-top: 3px solid var(--black);
		padding: 30px 0;
		width: 100%;
		flex-shrink: 0;
		z-index: 10;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 24px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16px;
		text-align: center;
	}

	.footer-copy {
		font-family: var(--font-sans-bold);
		font-weight: 700;
		font-size: 14px;
	}

	.f-red { color: var(--wirschaft-red); font-weight: 900; }
	.f-green { font-family: var(--font-script); color: var(--wirschaft-green); font-size: 24px; margin-left: -2px; }

	.footer-links {
		display: flex;
		align-items: center;
		gap: 12px;
	}

	/* RESPONSIVE HAMBURGER ICON DESIGN */
	.hamburger-box {
		width: 20px;
		height: 14px;
		display: block;
		position: relative;
	}
	.hamburger-inner, .hamburger-inner::before, .hamburger-inner::after {
		width: 20px;
		height: 2.5px;
		background-color: var(--black);
		position: absolute;
		border-radius: 2px;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}
	.hamburger-inner { top: 50%; transform: translateY(-50%); }
	.hamburger-inner::before { content: ""; top: -6px; }
	.hamburger-inner::after { content: ""; bottom: -6px; }

	.mobile-menu-toggle[aria-expanded="true"] .hamburger-inner { transform: rotate(45deg); }
	.mobile-menu-toggle[aria-expanded="true"] .hamburger-inner::before { opacity: 0; }
	.mobile-menu-toggle[aria-expanded="true"] .hamburger-inner::after { transform: translateY(6px) rotate(-90deg); }

	/* MOBILE NAV OVERLAY */
	.mobile-nav {
		position: fixed;
		top: var(--header-height);
		left: 0;
		right: 0;
		bottom: 0;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(246, 243, 236, 0.92) 100%);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		z-index: 90;
		transform: translateX(100%);
		transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
		padding: 30px 24px;
		overflow-y: auto;
		display: block;
	}

	.mobile-nav.is-active { transform: translateX(0); }
	body.menu-open { overflow: hidden; }

	.mobile-nav-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	/* Mobile Dropdown Menu Items */
	.mobile-dropdown-menu {
		list-style: none;
		padding: 10px 10px 0 16px;
		display: none;
		flex-direction: column;
		gap: 8px;
	}
	.mobile-dropdown-menu.is-visible { display: flex; }
	
	.mobile-dropdown-menu a {
		display: block;
		padding: 14px 18px;
		color: var(--black);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 13px;
		background: var(--white);
		border: 2px solid var(--black);
		border-radius: 12px;
		text-decoration: none;
		box-shadow: 0 4px 0 var(--black);
	}
	
	.mobile-dropdown-toggle svg { transition: transform 0.2s; }
	.mobile-dropdown-toggle.is-open svg { transform: rotate(180deg); }

	/* MEDIA BREAKPOINT FOR DESKTOP */
	@media (min-width: 992px) {
		.desktop-nav { display: block; }
		.mobile-menu-toggle { display: none; }
		.mobile-nav { display: none; }
		.footer-container {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
		}
	}
</style>s