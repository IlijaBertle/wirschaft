---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Fragment slot="title">AGs</Fragment>

  <section class="card">
    <h2>Arbeitsgemeinschaften</h2>
    <p>In unseren AGs entwickeln wir gemeinsam Projekte, lernen Neues und stärken die Gemeinschaft.</p>
  </section>
</Layout>

<style>
  .card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    line-height: 1.7;
  }
</style>
