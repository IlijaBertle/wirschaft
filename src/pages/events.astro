---
import Layout from "../layouts/Layout.astro";
import { client, urlFor } from "../lib/sanity";

interface Event {
  _id: string;
  title: string;
  date: string;
  caption?: string;
  image?: unknown;
}

const events = await client.fetch<Event[]>(`
*[_type=="event"] | order(date asc){
  _id,
  title,
  date,
  caption,
  image
}
`);
---

<Layout>
  <Fragment slot="title">Unsere Events</Fragment>

  <div class="container">
    <div class="grid">
      {events.map((event) => (
        <article class="card">
          {event.image && (
            <img
              src={urlFor(event.image).width(800).height(500).url()}
              alt={event.title}
            />
          )}

          <div class="content">
            <h2>{event.title}</h2>
            <div class="date">📅 {new Date(event.date).toLocaleDateString("de-DE")}</div>
            <p class="caption">{event.caption}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>

<style>
  .container {
    width: 100%;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .card {
    background: white;
    border-radius: 1.2rem;
    overflow: hidden;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 38px rgba(0, 0, 0, 0.12);
  }

  img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  .content {
    padding: 1.25rem;
  }

  h2 {
    font-size: 1.3rem;
    margin: 0 0 0.6rem;
    color: #c62828;
  }

  .date {
    color: #2e7d32;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .caption {
    color: #5b6472;
    line-height: 1.6;
    margin: 0;
  }
</style>