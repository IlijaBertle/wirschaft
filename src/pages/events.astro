---
import Layout from "../layouts/Layout.astro";
import { client, urlFor } from "../lib/sanity";

interface Event {
  _id: string;
  title: string;
  slug?: string;
  contentType?: "blog" | "event";
  date: string;
  caption?: string;
  image?: unknown;
  gallery?: unknown[];
}

const allEntries = await client.fetch<Event[]>(`
*[_type=="event"] | order(date desc){
  _id,
  title,
  "slug": slug.current,
  contentType,
  date,
  caption,
  image,
  gallery
}
`);

const now = new Date();
const upcomingEntries = allEntries
  .filter((entry) => entry.contentType === "event" ? new Date(entry.date) >= now : true)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastEntries = allEntries
  .filter((entry) => entry.contentType === "event" ? new Date(entry.date) < now : false)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout
  title="Aktuelles"
  description="Beiträge, Events und Geschichten rund um WIRschaft. Entdecken Sie aktuelle Inhalte, Hintergründe und Veranstaltungen."
>
  <div class="scrolly-container">
    <section class="reveal-section events-hero-section">
      <div class="content-box">
        <h1 class="script-title-green main-hero-title">Aktuelles <span class="sans-black">& Beiträge</span></h1>
        <p class="section-subtitle">Hier finden Sie Beiträge, Events und Geschichten aus der WIRschaft.</p>
        {upcomingEntries.length === 0 && pastEntries.length === 0 && (
          <p class="section-subtitle">Aktuell veröffentlichen wir noch keine Inhalte. Schau bald wieder vorbei!</p>
        )}
      </div>
    </section>

    {upcomingEntries.length > 0 && (
      <section class="reveal-section events-section">
        <div class="content-box wide-box">
          <h2 class="script-title-green">Neue <span class="sans-black">Inhalte</span></h2>
          <div class="events-grid">
            {upcomingEntries.map((entry) => {
              const entrySlug = entry.slug || entry._id;
              return (
                <a href={`/events/${entrySlug}`} class="event-card-link">
                  <article class="event-card">
                    {entry.image && (
                      <div class="event-card-img-wrapper">
                        <img
                          src={urlFor(entry.image).width(400).height(300).url()}
                          alt={entry.title}
                          loading="lazy"
                        />
                      </div>
                    )}

                    <div class="event-card-content">
                      <div class="event-date">
                        📅 {new Date(entry.date).toLocaleDateString("de-DE", { day: 'numeric', month: 'long', year: 'numeric' })}
                        {entry.contentType === "event" ? "" : " · Blog"}
                      </div>
                      <h3 class="event-card-title">{entry.title}</h3>
                      <p class="event-card-caption">{entry.caption}</p>
                      {entry.gallery && entry.gallery.length > 0 && (
                        <span class="event-meta-pill">📷 {entry.gallery.length} Bilder</span>
                      )}
                    </div>
                  </article>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {pastEntries.length > 0 && (
      <section class="reveal-section past-events-section">
        <div class="content-box wide-box">
          <h2 class="script-title-green">Frühere <span class="sans-black">Beiträge</span></h2>
          <div class="events-grid">
            {pastEntries.map((entry) => {
              const entrySlug = entry.slug || entry._id;
              return (
                <a href={`/events/${entrySlug}`} class="event-card-link">
                  <article class="event-card past-event-card">
                    {entry.image && (
                      <div class="event-card-img-wrapper">
                        <img
                          src={urlFor(entry.image).width(400).height(300).url()}
                          alt={entry.title}
                          loading="lazy"
                        />
                      </div>
                    )}

                    <div class="event-card-content">
                      <div class="event-date">
                        📅 {new Date(entry.date).toLocaleDateString("de-DE", { day: 'numeric', month: 'long', year: 'numeric' })}
                        {entry.contentType === "event" ? "" : " · Blog"}
                      </div>
                      <h3 class="event-card-title">{entry.title}</h3>
                      <p class="event-card-caption">{entry.caption}</p>
                      {entry.gallery && entry.gallery.length > 0 && (
                        <span class="event-meta-pill">📷 {entry.gallery.length} Bilder</span>
                      )}
                    </div>
                  </article>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  :root {
    --black: #111111;
    --wirschaft-red: #ff0000;
    --wirschaft-green: #00b341;
    --brutal-bg: #f6f3ec;
    --white: #ffffff;
    --font-sans-bold: 'Montserrat', sans-serif;
    --font-script: 'Caveat', cursive;
  }

  :global(.main-content) {
    background:
      linear-gradient(#e0dbd1 1px, transparent 1px),
      linear-gradient(90deg, #e0dbd1 1px, transparent 1px);
    background-size: 60px 60px;
    background-color: var(--brutal-bg) !important;
    padding: 0 !important;
  }

  .scrolly-container {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .reveal-section {
    min-height: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .events-hero-section {
    min-height: 35vh;
    justify-content: center;
    padding-bottom: 40px;
  }

  .events-section {
    padding: 40px 24px;
  }

  .past-events-section {
    padding: 80px 24px;
  }

  .content-box {
    width: 100%;
    max-width: 850px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .content-box.wide-box {
    max-width: 1200px;
    gap: 40px;
  }

  .script-title-green {
    font-family: var(--font-script);
    font-size: 76px;
    color: var(--wirschaft-green);
    line-height: 1.1;
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 16px;
  }

  .main-hero-title {
    font-size: 88px;
  }

  .sans-black {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    color: var(--black);
    font-size: 54px;
    letter-spacing: -2px;
    text-transform: uppercase;
  }

  .main-hero-title .sans-black {
    font-size: 62px;
  }

  .section-subtitle {
    font-size: 22px;
    font-weight: 700;
    color: var(--black);
    line-height: 1.4;
    margin: 0;
    max-width: 650px;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 32px;
  }

  .event-card-link {
    text-decoration: none;
    color: inherit;
  }

  .event-card {
    background: var(--white);
    border: 3px solid var(--black);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 10px 0 var(--black);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .event-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 0 var(--black);
  }

  .past-event-card {
    opacity: 0.75;
  }

  .past-event-card:hover {
    opacity: 1;
  }

  .event-card-img-wrapper {
    width: 100%;
    height: 220px;
    overflow: hidden;
    border-bottom: 3px solid var(--black);
  }

  .event-card-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .event-card-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .event-date {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    color: var(--wirschaft-green);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .event-card-title {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: 22px;
    letter-spacing: -0.5px;
    line-height: 1.2;
    margin: 0;
    color: var(--black);
  }

  .event-card-caption {
    font-size: 15px;
    line-height: 1.5;
    font-weight: 600;
    color: #444;
    margin: 0;
  }

  .event-meta-pill {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 12px;
    border-radius: 999px;
    background: #e0dbd1;
    color: var(--black);
    font-size: 12px;
    font-weight: 800;
    width: fit-content;
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .reveal-section {
      padding: 50px 16px;
    }

    .events-hero-section {
      min-height: auto;
    }

    .script-title-green {
      font-size: 52px;
      gap: 8px;
    }

    .main-hero-title {
      font-size: 58px;
    }

    .sans-black {
      font-size: 34px;
      letter-spacing: -1px;
    }

    .main-hero-title .sans-black {
      font-size: 38px;
    }

    .section-subtitle {
      font-size: 18px;
    }

    .events-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-section').forEach(section => {
    observer.observe(section);
  });
</script>