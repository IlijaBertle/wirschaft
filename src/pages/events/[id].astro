---
import Layout from "../../layouts/Layout.astro";
import { client, urlFor } from "../../lib/sanity";

interface Event {
  _id: string;
  title: string;
  slug?: string;
  date: string;
  caption?: string;
  description?: string;
  image?: {
    alt?: string;
    asset?: unknown;
  };
  gallery?: Array<{
    _key?: string;
    alt?: string;
    asset?: unknown;
  }>;
}

export async function getStaticPaths() {
  const events = await client.fetch<Event[]>(`
*[_type=="event"]{
  _id,
  title,
  "slug": slug.current,
  date,
  caption,
  description,
  image,
  gallery[] {
    _key,
    alt,
    asset
  }
}
  `);

  return events.map((event) => ({
    params: { id: event.slug || event._id },
    props: { event },
  }));
}

interface Props {
  event: Event;
}

const { event } = Astro.props;

const entryDate = event.date ? new Date(event.date) : null;
const formattedDate = entryDate
  ? entryDate.toLocaleDateString("de-DE", {
      weekday: "long",
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "Datum folgt";

const isoDate = entryDate?.toISOString();
const entrySlug = event.slug || event._id;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "https://wirschaft.de";
const pageUrl = `${siteUrl}/events/${entrySlug}`;
const heroImageUrl = event.image
  ? urlFor(event.image).width(1400).height(900).fit("crop").auto("format").quality(85).url()
  : `${siteUrl}/og-image.jpg`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: event.title,
  description: event.caption || event.description || `Erfahren Sie mehr über: ${event.title}`,
  datePublished: isoDate,
  author: {
    "@type": "Organization",
    name: "WIRschaft",
    url: siteUrl,
  },
  mainEntityOfPage: pageUrl,
  url: pageUrl,
  image: heroImageUrl,
  publisher: {
    "@type": "Organization",
    name: "WIRschaft",
    url: siteUrl,
  },
};
---

<Layout
  title={event.title}
  description={event.caption || event.description || `Erfahren Sie mehr über: ${event.title}`}
  ogImage={heroImageUrl}
  ogType="article"
  canonical={pageUrl}
  structuredData={structuredData}
>
  <div class="scrolly-container">
    <section class="reveal-section event-hero-section">
      <div class="content-box">
        <p class="eyebrow">Beitrag & Story</p>
        <h1 class="event-detail-title">{event.title}</h1>
        
        <div class="event-meta-detailed">
          <span class="meta-item">📅 {formattedDate}</span>
          {event.caption && <span class="meta-item">✍️ {event.caption}</span>}
        </div>
      </div>
    </section>

    <section class="reveal-section event-content-section">
      <div class="content-box wide-box">
        <article class="event-detail-card">
          {event.image && (
            <div class="detail-hero-image-wrapper">
              <img
                src={heroImageUrl}
                alt={event.image.alt || event.title}
                loading="eager"
                fetchpriority="high"
              />
            </div>
          )}

          <div class="event-detail-content">
            {event.caption && (
              <div class="event-caption">
                <p>{event.caption}</p>
              </div>
            )}

            {event.description && (
              <div class="event-description">
                <h2 class="content-title">Details</h2>
                <p>{event.description}</p>
              </div>
            )}

            {event.gallery && event.gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="content-title">Bildergalerie</h2>
                <div class="gallery-grid">
                  {event.gallery.map((image) => (
                    <figure class="gallery-card">
                      <img
                        src={urlFor(image).width(900).height(600).fit("crop").auto("format").quality(85).url()}
                        alt={image.alt || event.title}
                        loading="lazy"
                      />
                    </figure>
                  ))}
                </div>
              </div>
            )}

            <div class="action-wrapper">
              <a href="/events" class="brutal-btn large green-btn">
                ← Zurück zu Aktuelles
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>
  </div>
</Layout>

<style>
  :root {
    --black: #111111;
    --wirschaft-red: #ff0000;
    --wirschaft-green: #00b341;
    --brutal-bg: #f6f3ec;
    --white: #ffffff;
    --font-sans-bold: 'Montserrat', sans-serif;
    --font-script: 'Caveat', cursive;
  }

  :global(.main-content) {
    background:
      linear-gradient(#e0dbd1 1px, transparent 1px),
      linear-gradient(90deg, #e0dbd1 1px, transparent 1px);
    background-size: 60px 60px;
    background-color: var(--brutal-bg) !important;
    padding: 0 !important;
  }

  .scrolly-container {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .reveal-section {
    min-height: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .event-hero-section {
    min-height: 40vh;
    padding: 60px 24px;
  }

  .event-content-section {
    min-height: auto;
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .content-box {
    width: 100%;
    max-width: 750px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .content-box.wide-box {
    max-width: 1000px;
  }

  .event-detail-title {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: clamp(40px, 8vw, 60px);
    letter-spacing: -2px;
    line-height: 1.1;
    margin: 0;
    color: var(--black);
  }

  .event-meta-detailed {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    font-size: 18px;
  }

  .meta-item {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    color: var(--wirschaft-green);
  }

  .event-detail-card {
    background: var(--white);
    border: 3px solid var(--black);
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 14px 0 var(--black);
    display: flex;
    flex-direction: column;
  }

  .detail-hero-image-wrapper {
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-bottom: 3px solid var(--black);
  }

  .detail-hero-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .event-detail-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .eyebrow {
    display: inline-flex;
    align-self: flex-start;
    padding: 8px 12px;
    border: 2px solid var(--black);
    border-radius: 999px;
    background: var(--wirschaft-red);
    color: var(--white);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
  }

  .gallery-section {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }

  .gallery-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    border: 2px solid var(--black);
    border-radius: 18px;
    overflow: hidden;
    background: var(--white);
  }

  .gallery-card img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }

  .event-caption {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.6;
    color: #333;
  }

  .event-caption p {
    margin: 0;
  }

  .event-description {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .content-title {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: 24px;
    letter-spacing: -1px;
    margin: 0;
    color: var(--black);
  }

  .event-description p {
    font-size: 16px;
    line-height: 1.8;
    color: #444;
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .brutal-btn {
    appearance: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: 16px;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--black);
    border-radius: 20px;
    color: var(--black);
    transition: transform .1s ease, box-shadow .1s ease;
    box-shadow: 0 8px 0 var(--black);
  }

  .brutal-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 0 var(--black);
  }

  .brutal-btn:active {
    transform: translateY(8px);
    box-shadow: 0 0 0 var(--black);
  }

  .large {
    height: 64px;
    padding: 0 26px;
  }

  .green-btn { 
    background: var(--wirschaft-green); 
    color: var(--white); 
  }

  .action-wrapper {
    display: flex;
    justify-content: flex-start;
    margin-top: 15px;
  }

  @media (max-width: 768px) {
    .reveal-section {
      padding: 40px 16px;
    }

    .event-hero-section {
      min-height: auto;
      padding: 40px 16px;
    }

    .event-content-section {
      padding: 20px 16px 60px 16px;
    }

    .event-detail-title {
      font-size: clamp(28px, 6vw, 40px);
    }

    .event-meta-detailed {
      gap: 12px;
      font-size: 16px;
    }

    .event-detail-card {
      border-radius: 20px;
      box-shadow: 0 10px 0 var(--black);
    }

    .detail-hero-image-wrapper {
      height: 250px;
    }

    .event-detail-content {
      padding: 24px;
      gap: 18px;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .event-caption {
      font-size: 16px;
    }

    .content-title {
      font-size: 20px;
    }

    .event-description p {
      font-size: 15px;
    }
  }
</style>

<script>
  // Reveal Animation (Sektionen einblenden)
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-section').forEach(section => {
    observer.observe(section);
  });
</script>
