---
import Layout from "../../layouts/Layout.astro";
import { client, urlFor } from "../../lib/sanity";

interface Event {
  _id: string;
  title: string;
  date: string;
  caption?: string;
  description?: string;
  image?: unknown;
  location?: string;
  eventType?: string;
}

export async function getStaticPaths() {
  const events = await client.fetch<Event[]>(`
*[_type=="event"]{
  _id,
  title,
  date,
  caption,
  description,
  image,
  location,
  eventType
}
  `);

  return events.map((event) => ({
    params: { id: event._id },
    props: { event },
  }));
}

interface Props {
  event: Event;
}

const { event } = Astro.props;

const formattedDate = new Date(event.date).toLocaleDateString("de-DE", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});

const isoDate = new Date(event.date).toISOString();

// Structured Data für Schema.org Event
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: event.title,
  description: event.caption || event.description,
  startDate: isoDate,
  url: `https://wirschaft.de/events/${event._id}`,
  location: event.location ? {
    "@type": "Place",
    name: event.location,
  } : undefined,
  image: event.image ? urlFor(event.image).width(1200).height(600).url() : undefined,
  organizer: {
    "@type": "Organization",
    name: "WIRschaft",
    url: "https://wirschaft.de",
  },
};

// Entferne undefined Felder
Object.keys(structuredData).forEach(key => 
  structuredData[key] === undefined && delete structuredData[key]
);
---

<Layout
  title={event.title}
  description={event.caption || event.description || `Erfahren Sie mehr über: ${event.title}`}
  ogImage={event.image ? urlFor(event.image).width(1200).height(630).url() : "https://wirschaft.de/og-image.jpg"}
  ogType="event"
  canonical={`https://wirschaft.de/events/${event._id}`}
  structuredData={structuredData}
>
  <div class="scrolly-container">
    <section class="reveal-section event-hero-section">
      <div class="content-box">
        <h1 class="event-detail-title">{event.title}</h1>
        
        <div class="event-meta-detailed">
          <span class="meta-item">📅 {formattedDate}</span>
          {event.location && <span class="meta-item">📍 {event.location}</span>}
        </div>
      </div>
    </section>

    <section class="reveal-section event-content-section">
      <div class="content-box wide-box">
        <div class="event-detail-card">
          {event.image && (
            <div class="detail-hero-image-wrapper">
              <img
                src={urlFor(event.image).width(1200).height(600).url()}
                alt={event.title}
                loading="eager"
              />
            </div>
          )}

          <div class="event-detail-content">
            {event.caption && (
              <div class="event-caption">
                <p>{event.caption}</p>
              </div>
            )}

            {event.description && (
              <div class="event-description">
                <h2 class="content-title">Details</h2>
                <p>{event.description}</p>
              </div>
            )}

            <div class="action-wrapper">
              <a href="/events" class="brutal-btn large green-btn">
                ← Zurück zu Events
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  :root {
    --black: #111111;
    --wirschaft-red: #ff0000;
    --wirschaft-green: #00b341;
    --brutal-bg: #f6f3ec;
    --white: #ffffff;
    --font-sans-bold: 'Montserrat', sans-serif;
    --font-script: 'Caveat', cursive;
  }

  :global(.main-content) {
    background:
      linear-gradient(#e0dbd1 1px, transparent 1px),
      linear-gradient(90deg, #e0dbd1 1px, transparent 1px);
    background-size: 60px 60px;
    background-color: var(--brutal-bg) !important;
    padding: 0 !important;
  }

  .scrolly-container {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  .reveal-section {
    min-height: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .event-hero-section {
    min-height: 40vh;
    padding: 60px 24px;
  }

  .event-content-section {
    min-height: auto;
    padding-top: 40px;
    padding-bottom: 80px;
  }

  .content-box {
    width: 100%;
    max-width: 750px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .content-box.wide-box {
    max-width: 1000px;
  }

  .event-detail-title {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: clamp(40px, 8vw, 60px);
    letter-spacing: -2px;
    line-height: 1.1;
    margin: 0;
    color: var(--black);
  }

  .event-meta-detailed {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    font-size: 18px;
  }

  .meta-item {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    color: var(--wirschaft-green);
  }

  .event-detail-card {
    background: var(--white);
    border: 3px solid var(--black);
    border-radius: 32px;
    overflow: hidden;
    box-shadow: 0 14px 0 var(--black);
    display: flex;
    flex-direction: column;
  }

  .detail-hero-image-wrapper {
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-bottom: 3px solid var(--black);
  }

  .detail-hero-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .event-detail-content {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .event-caption {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.6;
    color: #333;
  }

  .event-caption p {
    margin: 0;
  }

  .event-description {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .content-title {
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: 24px;
    letter-spacing: -1px;
    margin: 0;
    color: var(--black);
  }

  .event-description p {
    font-size: 16px;
    line-height: 1.8;
    color: #444;
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .brutal-btn {
    appearance: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans-bold);
    font-weight: 900;
    font-size: 16px;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--black);
    border-radius: 20px;
    color: var(--black);
    transition: transform .1s ease, box-shadow .1s ease;
    box-shadow: 0 8px 0 var(--black);
  }

  .brutal-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 0 var(--black);
  }

  .brutal-btn:active {
    transform: translateY(8px);
    box-shadow: 0 0 0 var(--black);
  }

  .large {
    height: 64px;
    padding: 0 26px;
  }

  .green-btn { 
    background: var(--wirschaft-green); 
    color: var(--white); 
  }

  .action-wrapper {
    display: flex;
    justify-content: flex-start;
    margin-top: 15px;
  }

  @media (max-width: 768px) {
    .reveal-section {
      padding: 40px 16px;
    }

    .event-hero-section {
      min-height: auto;
      padding: 40px 16px;
    }

    .event-content-section {
      padding: 20px 16px 60px 16px;
    }

    .event-detail-title {
      font-size: clamp(28px, 6vw, 40px);
    }

    .event-meta-detailed {
      gap: 12px;
      font-size: 16px;
    }

    .event-detail-card {
      border-radius: 20px;
      box-shadow: 0 10px 0 var(--black);
    }

    .detail-hero-image-wrapper {
      height: 250px;
    }

    .event-detail-content {
      padding: 24px;
      gap: 18px;
    }

    .event-caption {
      font-size: 16px;
    }

    .content-title {
      font-size: 20px;
    }

    .event-description p {
      font-size: 15px;
    }
  }
</style>

<script>
  // Reveal Animation (Sektionen einblenden)
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal-section').forEach(section => {
    observer.observe(section);
  });
</script>
