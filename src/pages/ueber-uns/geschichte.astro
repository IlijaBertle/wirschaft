---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <Fragment slot="title">Geschichte</Fragment>

  <section class="card">
    <h2>Unsere Geschichte</h2>
    <p>Alles begann mit einer kleinen Idee und einer starken Gemeinschaft. Aus dieser Idee wurde eine Plattform mit vielen Projekten.</p>
  </section>
</Layout>

<style>
  .card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    line-height: 1.7;
  }
</style>
