---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <Fragment slot="title">Das erste Jahr</Fragment>

  <section class="card">
    <h2>Ein starkes erstes Jahr</h2>
    <p>Im ersten Jahr haben wir viele Menschen erreicht und unsere erste große Projektphase begonnen.</p>
  </section>
</Layout>

<style>
  .card {
    background: white;
    border-radius: 1.2rem;
    padding: 1.5rem;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
    line-height: 1.7;
  }
</style>
