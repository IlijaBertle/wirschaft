---
import Header from '../components/Header.astro';

// Beispielhafte Event-Daten passend zu deiner Struktur
const events = [
  {
    title: "Netzwerktreffen AG Zukunft",
    date: "2026-07-15T19:00:00",
    caption: "Gemeinsame Ausarbeitung unserer neuen Visionen und Jahresthemen im Hauptsaal.",
    image: null // Setze hier ein Sanity-Bildobjekt ein, falls vorhanden
  },
  {
    title: "Kreativ-Workshop: Wie alles begann",
    date: "2026-08-02T14:30:00",
    caption: "Ein interaktiver Nachmittag über die Entstehungsgeschichte unserer Gemeinschaft.",
    image: null
  }
];

// Sanity URL-Builder Platzhalterfunktion (falls du sie nutzt, ansonsten durch echte Imports ersetzen)
const urlFor = (source: any) => ({
  width: (w: number) => ({
    height: (h: number) => ({
      url: () => "https://picsum.photos/" + w + "/" + h // Fallback-Bilder
    })
  })
});
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WIRschaft - Homepage</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
</head>
<body>

  <Header />

  <main>
    <section class="hero-section">
      <div class="hero-bg-accent"></div>
      <div class="container hero-grid">
        <div class="hero-content">
          <span class="badge">Unsere Philosophie</span>
          <h1>Warum das alles? Weil Gemeinschaft Zukunft schafft.</h1>
          <p>Willkommen bei der <strong>WIRschaft</strong>. Wir vereinen Ideen, Tatkraft und Menschen in Arbeitsgruppen (AGs), um gemeinsam neue Wege zu gehen.</p>
          <div class="hero-actions">
            <a href="#ags" class="btn btn-primary">Unsere AGs entdecken</a>
            <a href="#ueber-uns" class="btn btn-secondary">Mehr über uns</a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="image-card-deco"></div>
          <div class="image-card">
            <img src="/logo.png" alt="WIRschaft Großansicht" />
          </div>
        </div>
      </div>
    </section>

    <section id="ueber-uns" class="info-section">
      <div class="container">
        <div class="section-header">
          <h2>Über die WIRschaft</h2>
          <div class="accent-line"></div>
        </div>
        <div class="info-grid">
          <div class="info-box">
            <h3>Wie alles begann</h3>
            <p>Aus einer kleinen Idee entstand eine dynamische Bewegung. Erfahre mehr über unsere ersten Impulse und Meilensteine.</p>
          </div>
          <div class="info-box">
            <h3>Das erste Jahr</h3>
            <p>Ein Jahr voller Herausforderungen, Erfolge und unvergesslicher Teammomente. Wir blicken stolz zurück.</p>
          </div>
          <div class="info-box">
            <h3>Das Team</h3>
            <p>Köpfe voller Ideen. Unsere Mitglieder bringen unterschiedlichste Kompetenzen in die Arbeitsgruppen ein.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="termine" class="events-section">
      <div class="container">
        <div class="section-header">
          <h2>Unsere Events & Termine</h2>
          <div class="accent-line"></div>
        </div>

        <div class="grid">
          {events.map((event) => (
            <div class="card">
              {event.image ? (
                <img
                  src={urlFor(event.image).width(800).height(500).url()}
                  alt={event.title}
                  class="event-img"
                />
              ) : (
                <div class="event-img-placeholder">
                  <span>📅 WIRschaft Event</span>
                </div>
              )}

              <div class="content">
                <h2>{event.title}</h2>
                <div class="date">
                  📅 {new Date(event.date).toLocaleDateString("de-DE", { day: 'numeric', month: 'long', year: 'numeric' })}
                </div>
                <p class="caption">
                  {event.caption}
                </p>
              </div>
            </div>
          ))}
        </div>

        <div class="more-events-wrapper">
          <a href="/event" class="btn-more">
            Mehr anzeigen <span class="arrow-right">→</span>
          </a>
        </div>
      </div>
    </section>

    <section class="map-section">
      <div class="container">
        <div class="section-header">
          <h2>Hier findest du uns</h2>
          <div class="accent-line"></div>
        </div>
        <p class="map-description">Unsere Treffen finden regelmäßig an wechselnden Orten oder in unserem Hauptstützpunkt statt.</p>
        
        <div id="map"></div>
      </div>
    </section>
  </main>

  <footer class="main-footer">
    <p>&copy; {new Date().getFullYear()} WIRschaft. Alle Rechte vorbehalten.</p>
  </footer>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  
  <script>
    // --- LOCATION HIER EINSTELLEN ---
    // Breitengrad (Lat) und Längengrad (Lng) für deinen Standort (Beispiel: Penzberg)
    const latitude = 47.7505;
    const longitude = 11.3743;
    const zoomLevel = 15;

    // Karte initialisieren
    // @ts-ignore (Verhindert TypeScript-Warnungen in Astro für globale Leaflet-Variable)
    const map = L.map('map').setView([latitude, longitude], zoomLevel);

    // OpenStreetMap Kartenkacheln laden
    // @ts-ignore
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>-Mitwirkende'
    }).addTo(map);

    // Pin/Marker hinzufügen
    // @ts-ignore
    L.marker([latitude, longitude]).addTo(map)
      .bindPopup('<b>WIRschaft Treffpunkt</b><br>Hier kommen wir zusammen.')
      .openPopup();
  </script>
</body>
</html>

<style>
  :root {
    --primary-yellow: #FFFE88;
    --primary-yellow-hover: #fcf960;
    --dark-text: #222222;
    --light-gray: #f9f9f9;
    --border-color: #eaeaea;
  }

  body {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    margin: 0;
    padding: 0;
    color: var(--dark-text);
    background-color: #ffffff;
    padding-top: 70px; /* Platz für fixierten Header */
    scroll-behavior: smooth;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  section {
    padding: 80px 0;
  }

  .section-header {
    margin-bottom: 40px;
  }

  .section-header h2 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .accent-line {
    width: 60px;
    height: 4px;
    background-color: var(--primary-yellow);
    border-radius: 2px;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--primary-yellow);
    color: var(--dark-text);
  }

  .btn-primary:hover {
    background-color: var(--primary-yellow-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background-color: var(--light-gray);
    color: var(--dark-text);
    border: 1px solid var(--border-color);
  }

  .btn-secondary:hover {
    background-color: #eee;
  }

  /* Hero Section */
  .hero-section {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #ffffff 0%, #fffdec 100%);
  }

  .hero-bg-accent {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    background-color: var(--primary-yellow);
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.4;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .badge {
    background: var(--primary-yellow);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .hero-content h1 {
    font-size: 3rem;
    line-height: 1.15;
    margin: 20px 0;
  }

  .hero-content p {
    font-size: 1.15rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .image-card {
    background: white;
    padding: 20px;
    border-radius: 16px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    z-index: 2;
  }

  .image-card img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }

  .image-card-deco {
    position: absolute;
    width: 100%;
    height: 100%;
    background-color: var(--primary-yellow);
    bottom: -15px;
    right: -15px;
    border-radius: 16px;
    z-index: 1;
  }

  /* Info Section */
  .info-section {
    background-color: var(--light-gray);
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
  }

  .info-box {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.01);
    border-top: 4px solid var(--primary-yellow);
  }

  /* Event Section Design-Optimierungen */
  .events-section {
    background-color: #ffffff;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 30px;
  }

  .card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid var(--border-color);
    transition: transform 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .event-img, .event-img-placeholder {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  .event-img-placeholder {
    background-color: #fffdec;
    border-bottom: 2px solid var(--primary-yellow);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    color: #666;
  }

  .card .content {
    padding: 24px;
  }

  .card h2 {
    font-size: 1.4rem;
    margin: 0 0 12px 0;
  }

  .date {
    font-size: 0.9rem;
    color: #666;
    background-color: var(--light-gray);
    padding: 6px 12px;
    border-radius: 6px;
    display: inline-block;
    margin-bottom: 14px;
  }

  .caption {
    color: #555;
    line-height: 1.5;
    margin: 0;
  }

  .more-events-wrapper {
    text-align: center;
    margin-top: 50px;
  }

  .btn-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--dark-text);
    color: white;
    padding: 14px 32px;
    border-radius: 30px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s ease;
  }

  .btn-more:hover {
    background: #000;
  }

  .arrow-right {
    transition: transform 0.2s ease;
  }

  .btn-more:hover .arrow-right {
    transform: translateX(4px);
  }

  /* OpenStreetMap Map Styles */
  .map-description {
    margin-bottom: 24px;
    color: #555;
  }

  #map {
    width: 100%;
    height: 450px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 4px solid white;
    z-index: 1; /* Verhindert Konflikte mit dem Header */
  }

  /* Footer */
  .main-footer {
    text-align: center;
    padding: 40px 0;
    background-color: var(--dark-text);
    color: #888;
    font-size: 0.9rem;
  }

  /* Mobile Anpassungen */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    
    .hero-bg-accent {
      width: 250px;
      height: 250px;
    }

    .hero-content h1 {
      font-size: 2.2rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-visual {
      order: -1; /* Bild rückt mobil nach oben */
      max-width: 300px;
      margin: 0 auto;
    }

    #map {
      height: 300px;
    }
  }
</style>