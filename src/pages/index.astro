---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Startseite | WIRschaft" 
	description="Wirtschaft, Geschichte und Events klar strukturiert."
>
	<!-- Google Fonts direkt laden, um den Stil aus 'LogoWIRschaft gelb.png' zu matchen -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Montserrat:wght@900&display=swap" rel="stylesheet">

	<div class="scrolly-container">
		
		<!-- ABSCHNITT 1: HERO & TOP-BUTTONS -->
		<section class="reveal-section full-screen-hero">
			<div class="content-box">
				<div class="logo-inspired-title">
					<span class="text-red-bold">WIR</span><span class="text-green-script">schaft</span>
				</div>
				<p class="section-subtitle">Starke Wirtschaft. Gelebte Geschichte. Gemeinsame Events.</p>
				
				<div class="brutal-btn-group">
					<a href="/ueber-uns/geschichte" class="brutal-btn large white-btn">
						⏳ Unsere Geschichte
					</a>
					<a href="#gallery-section" class="brutal-btn large green-btn">
						📈 Wirtschaft
					</a>
					<a href="#next-event-section" class="brutal-btn large red-btn">
						📅 Aktuelle Events
					</a>
				</div>
			</div>
		</section>

		<!-- ABSCHNITT 2: SEITWÄRTS-GALERIE -->
		<section id="gallery-section" class="reveal-section full-screen-gallery">
			<div class="content-box wide-box">
				<div class="gallery-header">
					<h2 class="script-title-green">Einblicke <span class="sans-black">& Galerie</span></h2>
					<p>Wische oder scrolle einfach seitwärts, um mehr zu sehen.</p>
				</div>
				
				<div class="horizontal-scroll-track">
					<div class="brutal-gallery-card">
						<img src="/galerie-1.jpg" alt="Das erste Jahr" />
						<div class="card-label">Das erste Jahr</div>
					</div>
					<div class="brutal-gallery-card">
						<img src="/galerie-2.jpg" alt="Unser Team" />
						<div class="card-label">Unser Team</div>
					</div>
					<div class="brutal-gallery-card">
						<img src="/galerie-3.jpg" alt="Wirtschaftsnetzwerk" />
						<div class="card-label">Wirtschaftsnetzwerk</div>
					</div>
					<div class="brutal-gallery-card">
						<img src="/galerie-4.jpg" alt="Letztes Event" />
						<div class="card-label">Letztes Event</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ABSCHNITT 3: NÄCHSTES EVENT -->
		<section id="next-event-section" class="reveal-section full-screen-event">
			<div class="content-box">
				<div class="event-hero-card">
					<span class="mini-badge-red">HIGHLIGHT</span>
					<h2 class="event-main-title">Großes Netzwerktreffen 2026</h2>
					<p class="event-time-place">📍 Hauptsaal & Online | 📅 15. Juli 2026 | ⏰ 18:00 Uhr</p>
					<p class="event-teaser">
						Tauschen Sie sich mit führenden Köpfen aus Wirtschaft und Praxis aus. 
						Es erwarten Sie spannende Vorträge zu unseren aktuellen Arbeitsgemeinschaften.
					</p>
				</div>

				<div class="center-action-wrapper">
					<a href="/events" class="brutal-btn large green-btn dynamic-width">
						Alle Events anzeigen →
					</a>
				</div>
			</div>
		</section>

	</div>
</Layout>

<style>
	/* FARB- & SCHRIFTKONFIGURATION BASIEREND AUF LOGOWIRSCHAFT GELB.PNG */
	:root {
		--black: #111111;
		--wirschaft-red: #ff0000;      /* Signalrot aus dem "WIR"-Schriftzug */
		--wirschaft-green: #00b341;    /* Sattes Grün aus dem "schaft"-Schriftzug */
		--brutal-bg: #f6f3ec;
		--white: #ffffff;
		
		/* Fonts */
		--font-sans-bold: 'Montserrat', sans-serif;
		--font-script: 'Caveat', cursive;
	}

	/* Jede Sektion füllt exakt den Viewport aus */
	.scrolly-container {
		width: 100%;
		display: flex;
		flex-direction: column;
	}

	/* Globaler Karo-Hintergrund bleibt bestehen */
	:global(.main-content) {
		background:
			linear-gradient(#e0dbd1 1px, transparent 1px),
			linear-gradient(90deg, #e0dbd1 1px, transparent 1px);
		background-size: 60px 60px;
		background-color: var(--brutal-bg) !important;
		padding: 0 !important; /* Volle Höhe nutzen ohne Padding-Einschränkung */
	}

	/* REVEAL SYSTEM (Einblenden beim Scrollen) */
	.reveal-section {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 40px 24px;
		opacity: 0;
		transform: translateY(40px);
		transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
	}

	/* Wird via JavaScript getriggert */
	.reveal-section.is-visible {
		opacity: 1;
		transform: translateY(0);
	}

	.content-box {
		width: 100%;
		max-width: 750px;
		display: flex;
		flex-direction: column;
		gap: 30px;
	}

	.content-box.wide-box {
		max-width: 1100px;
	}

	/* TYPOGRAFIE AUS DEM BILD 'LogoWIRschaft gelb.png' */
	.logo-inspired-title {
		font-size: clamp(65px, 15vw, 130px);
		line-height: 0.9;
		letter-spacing: -3px;
		margin-bottom: 10px;
	}

	.text-red-bold {
		font-family: var(--font-sans-bold);
		font-weight: 900;
		color: var(--wirschaft-red);
	}

	.text-green-script {
		font-family: var(--font-script);
		color: var(--wirschaft-green);
		font-weight: 700;
		letter-spacing: 0px;
		margin-left: -5px; /* Lässt das Cursive fließend in das WIR übergehen */
	}

	.section-subtitle {
		font-size: 20px;
		font-weight: 700;
		color: var(--black);
		line-height: 1.4;
	}

	/* SCHRIFT-VARIANTE FÜR SEKTIONS-TITEL */
	.script-title-green {
		font-family: var(--font-script);
		font-size: 55px;
		color: var(--wirschaft-green);
		line-height: 1;
	}
	.sans-black {
		font-family: var(--font-sans-bold);
		font-weight: 900;
		color: var(--black);
		font-size: 38px;
		letter-spacing: -2px;
		display: inline-block;
		transform: translateY(-8px);
	}

	/* BRUTALIST RETRO KNOEPFE */
	.brutal-btn-group {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.brutal-btn {
		appearance: none;
		border: none;
		outline: none;
		cursor: pointer;
		font-family: var(--font-sans-bold);
		font-weight: 900;
		font-size: 16px;
		text-transform: uppercase;
		text-decoration: none;
		text-align: center;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 3px solid var(--black);
		border-radius: 20px;
		color: var(--black);
		transition: transform .1s ease, box-shadow .1s ease, background .1s ease;
		box-shadow: 0 8px 0 var(--black);
	}

	.brutal-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 0 var(--black);
	}

	.brutal-btn:active {
		transform: translateY(8px);
		box-shadow: 0 0 0 var(--black);
	}

	.large {
		height: 64px;
		padding: 0 26px;
	}

	.red-btn {
		background: var(--wirschaft-red);
		color: var(--white);
	}
	.green-btn {
		background: var(--wirschaft-green);
		color: var(--white);
	}
	.white-btn {
		background: var(--white);
	}

	.dynamic-width {
		width: 100%;
		max-width: 450px;
	}

	/* SEITWÄRTS SCHIEBENDE BILDERGALERIE */
	.gallery-header {
		margin-bottom: 10px;
	}
	.gallery-header p {
		font-weight: 700;
		color: #555;
	}

	.horizontal-scroll-track {
		display: flex;
		gap: 24px;
		overflow-x: auto;
		padding: 10px 10px 20px 0;
		scroll-snap-type: x mandatory;
		scrollbar-width: auto;
	}

	/* Scrollbar Styling */
	.horizontal-scroll-track::-webkit-scrollbar { height: 12px; }
	.horizontal-scroll-track::-webkit-scrollbar-track {
		background: var(--white);
		border: 3px solid var(--black);
		border-radius: 10px;
	}
	.horizontal-scroll-track::-webkit-scrollbar-thumb {
		background: var(--wirschaft-green);
		border: 2px solid var(--black);
		border-radius: 8px;
	}

	.brutal-gallery-card {
		flex: 0 0 320px;
		scroll-snap-align: start;
		background: var(--white);
		border: 3px solid var(--black);
		border-radius: 24px;
		overflow: hidden;
		box-shadow: 0 8px 0 var(--black);
	}

	.brutal-gallery-card img {
		width: 100%;
		height: 220px;
		object-fit: cover;
		display: block;
		border-bottom: 3px solid var(--black);
	}

	.card-label {
		padding: 14px;
		font-family: var(--font-sans-bold);
		font-weight: 900;
		font-size: 14px;
		text-align: center;
	}

	/* EVENT SEKTION ELEMENTE */
	.event-hero-card {
		background: var(--white);
		border: 3px solid var(--black);
		border-radius: 32px;
		padding: 40px;
		box-shadow: 0 14px 0 var(--black);
	}

	.mini-badge-red {
		background: var(--wirschaft-red);
		color: var(--white);
		font-family: var(--font-sans-bold);
		font-weight: 900;
		padding: 4px 10px;
		font-size: 11px;
		border: 2px solid var(--black);
		border-radius: 6px;
		display: inline-block;
		margin-bottom: 15px;
	}

	.event-main-title {
		font-family: var(--font-sans-bold);
		font-weight: 900;
		font-size: clamp(28px, 5vw, 42px);
		letter-spacing: -1.5px;
		line-height: 1.1;
		margin-bottom: 12px;
	}

	.event-time-place {
		font-family: var(--font-sans-bold);
		font-weight: 900;
		color: var(--wirschaft-green);
		font-size: 14px;
		margin-bottom: 20px;
	}

	.event-teaser {
		font-size: 16px;
		line-height: 1.6;
		font-weight: 600;
		color: #333;
	}

	.center-action-wrapper {
		display: flex;
		justify-content: center;
		width: 100%;
		margin-top: 10px;
	}

	/* RESPONSIVE BREAKPOINTS */
	@media (min-width: 768px) {
		.brutal-gallery-card { flex: 0 0 380px; }
	}
</style>

<!-- JAVASCRIPT: Schrittweises Einblenden beim Scrollen (Intersection Observer) -->
<script>
	const observerOptions = {
		root: null,
		rootMargin: '0px',
		threshold: 0.15 // Sobald 15% der Sektion sichtbar sind, blendet sie ein
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('is-visible');
			}
		});
	}, observerOptions);

	// Alle Abschnitte erfassen und an den Observer hängen
	document.querySelectorAll('.reveal-section').forEach(section => {
		observer.observe(section);
	});
</script>