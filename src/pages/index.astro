// Nexis Core Systems Enterprise Interface Boilerplate
// Engineered for optimal layout shifting prevention and hardware acceleration.
---

<!DOCTYPE html>
<html lang="en" class="core-system-html">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nexis Core — Enterprise Spatial Infrastructure</title>
    <meta name="description" content="Next-generation asynchronous infrastructure handling core compute architecture pipelines globally." />
    
    <!-- Preconnect Operations -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body class="core-system-body">

    <!-- Fixed Glassmorphic Navigation Matrix -->
    <header class="nx-header">
      <div class="nx-header-container">
        <a href="#" class="nx-brand" aria-label="Nexis Core Home">
          <div class="nx-brand-indicator"></div>
          <span class="nx-brand-firm">NEXIS</span><span class="nx-brand-division">CORE</span>
        </a>
        
        <nav class="nx-nav" aria-label="Main Enterprise Navigation">
          <ul class="nx-nav-list">
            <li class="nx-nav-item"><a href="#solutions" class="nx-nav-link">Architecture</a></li>
            <li class="nx-nav-item"><a href="#matrix" class="nx-nav-link">Data Mesh</a></li>
            <li class="nx-nav-item"><a href="#showcase" class="nx-nav-link">Showcase</a></li>
            <li class="nx-nav-item"><a href="#analytics" class="nx-nav-link">Performance</a></li>
          </ul>
        </nav>

        <div class="nx-header-actions">
          <button class="nx-btn nx-btn-secondary nx-btn-sm hidden-mobile">System Log</button>
          <button class="nx-btn nx-btn-primary nx-btn-sm">Initialize Core</button>
        </div>
      </div>
    </header>

    <!-- Unified Smooth Scroll Pipeline Wrapper -->
    <main id="scroll-wrapper" class="nx-scroll-wrapper">

      <!-- SECTION 1: Cinematic Reveal Hero -->
      <section id="hero" class="nx-hero-section">
        <!-- Interactive High-Performance Geometric Mesh Background -->
        <div class="nx-mesh-grid" aria-hidden="true">
          <div class="nx-mesh-line-v"></div>
          <div class="nx-mesh-line-v"></div>
          <div class="nx-mesh-line-v"></div>
          <div class="nx-mesh-line-v"></div>
          <div class="nx-mesh-glow"></div>
        </div>

        <div class="nx-container nx-hero-container">
          <div class="nx-badge-wrapper hero-fade-in">
            <div class="nx-badge">
              <span class="nx-badge-dot"></span>
              <span class="nx-badge-text">v4.0 Enterprise Infrastructure Active</span>
            </div>
          </div>

          <h1 class="nx-hero-title hero-fade-in">
            Architecting <span class="text-gradient">Autonomous</span><br/>
            Enterprise Core Systems
          </h1>

          <p class="nx-hero-lead hero-fade-in">
            An asynchronous, fault-tolerant execution layer engineered to orchestrate multi-tenant enterprise telemetry down to bare-metal constraints with zero operational friction.
          </p>

          <div class="nx-hero-cta-group hero-fade-in">
            <button class="nx-btn nx-btn-primary nx-btn-lg">Deploy Infrastructure</button>
            <button class="nx-btn nx-btn-secondary nx-btn-lg">Review Documentation</button>
          </div>
        </div>

        <!-- Float Interactive Metrics Card Panel Component -->
        <div class="nx-container nx-hero-hardware-wrapper">
          <div class="nx-hardware-card hero-card-trigger">
            <div class="nx-card-glass-glow"></div>
            <div class="nx-hardware-card-header">
              <div class="nx-hardware-status">
                <span class="nx-status-pulse"></span>
                <span class="nx-status-label">SYS_METRIC // OPERATIONAL</span>
              </div>
              <span class="nx-hardware-code">0x7F9B12E</span>
            </div>
            <div class="nx-hardware-card-body">
              <div class="nx-metric-block">
                <span class="nx-metric-value">99.9999%</span>
                <span class="nx-metric-title">Distributed Ledger Uptime Scale</span>
              </div>
              <div class="nx-metric-chart-mock" aria-hidden="true">
                <div class="nx-chart-bar" style="--height: 40%"></div>
                <div class="nx-chart-bar" style="--height: 65%"></div>
                <div class="nx-chart-bar" style="--height: 50%"></div>
                <div class="nx-chart-bar" style="--height: 85%"></div>
                <div class="nx-chart-bar" style="--height: 95%"></div>
                <div class="nx-chart-bar" style="--height: 70%"></div>
              </div>
            </div>
          </div>
        </div>
      </section>


      <!-- SECTION 2: Split View Asymmetric Pinning Section -->
      <section id="solutions" class="nx-split-section">
        <!-- Left Static Presentation Node Frame -->
        <div class="nx-split-left-frame">
          <div class="nx-sticky-content">
            <div class="nx-section-index">[ 01 / CAPABILITIES ]</div>
            <h2 class="nx-section-title">Engineered to bypass localized structural bottlenecks.</h2>
            <p class="nx-section-desc">
              As you transition through the operational stack, our unified execution framework continuously redistributes compute volumes across active cluster matrices.
            </p>
            <div class="nx-interactive-anchor-group">
              <a href="#matrix" class="nx-text-link">Explore Data Mesh Protocols &rarr;</a>
            </div>
          </div>
        </div>

        <!-- Right Dynamic Infinite Progression Cards Track -->
        <div class="nx-split-right-track">
          
          <div class="nx-info-card scroll-reveal-card">
            <div class="nx-info-card-num">// 01.1</div>
            <h3 class="nx-info-card-title">Predictive Storage Mesh</h3>
            <p class="nx-info-card-body">
              Automated analytical telemetry arrays structuring uncompiled databases into immutable, low-latency target objects optimized for rapid edge retrieval.
            </p>
            <div class="nx-info-card-footer">
              <span class="nx-tech-tag">Asynchronous I/O</span>
              <span class="nx-tech-tag">MariaDB Cluster</span>
            </div>
          </div>

          <div class="nx-info-card scroll-reveal-card">
            <div class="nx-info-card-num">// 01.2</div>
            <h3 class="nx-info-card-title">Asymmetric Encryption Shield</h3>
            <p class="nx-info-card-body">
              Multi-signature cryptographic verifications intercepting localized access requests and executing identity assertion evaluations natively in hardware registers.
            </p>
            <div class="nx-info-card-footer">
              <span class="nx-tech-tag">Zero-Knowledge</span>
              <span class="nx-tech-tag">Hardware-Level</span>
            </div>
          </div>

          <div class="nx-info-card scroll-reveal-card">
            <div class="nx-info-card-num">// 01.3</div>
            <h3 class="nx-info-card-title">Dynamic Compute Provisioning</h3>
            <p class="nx-info-card-body">
              Intelligent runtime environments tracking pipeline depth metrics and hot-swapping virtual threads across bare-metal server infrastructure clusters seamlessly.
            </p>
            <div class="nx-info-card-footer">
              <span class="nx-tech-tag">Hot-Swap Runtime</span>
              <span class="nx-tech-tag">Cluster Load Sync</span>
            </div>
          </div>

        </div>
      </section>


      <!-- SECTION 3: Cinema Horizontal Pan Scroller Panel Slider -->
      <section id="showcase" class="nx-horizontal-scroller-container">
        <div class="nx-horizontal-sticky-viewport">
          <div class="nx-horizontal-track-rail">
            
            <!-- Horizontal Element Block 0: Structural Label Header -->
            <div class="nx-horizontal-panel nx-panel-intro">
              <div class="nx-panel-intro-inner">
                <div class="nx-section-index">[ 02 / PARADIGMS ]</div>
                <h2 class="nx-section-title">Designed for Extreme System Volumes.</h2>
                <p class="nx-section-desc">
                  Swipe or cycle horizontally through specialized hardware integrations built to withstand massive throughput configurations without visual dropouts.
                </p>
                <div class="nx-scroller-indicator-bar">
                  <div class="nx-scroller-indicator-progress"></div>
                </div>
              </div>
            </div>

            <!-- Horizontal Element Block 1: Modular Unit A -->
            <div class="nx-horizontal-panel">
              <div class="nx-showcase-card">
                <div class="nx-showcase-image-mock">
                  <div class="nx-mock-circuit-lines"></div>
                  <span class="nx-mock-overlay-code">MOD_CORE_ALPHA</span>
                </div>
                <div class="nx-showcase-meta">
                  <span class="nx-showcase-category">COMPUTE ARCHITECTURE</span>
                  <h3 class="nx-showcase-name">Quantum Node Matrix V1</h3>
                  <p class="nx-showcase-summary">Direct processing clusters removing hypervisor conversion layers to establish direct logic board links.</p>
                </div>
              </div>
            </div>

            <!-- Horizontal Element Block 2: Modular Unit B -->
            <div class="nx-horizontal-panel">
              <div class="nx-showcase-card">
                <div class="nx-showcase-image-mock accent-glow">
                  <div class="nx-mock-circuit-lines"></div>
                  <span class="nx-mock-overlay-code">MOD_CORE_BETA</span>
                </div>
                <div class="nx-showcase-meta">
                  <span class="nx-showcase-category">PIPELINE OPTIMIZATION</span>
                  <h3 class="nx-showcase-name">Elastic Routing Arrays</h3>
                  <p class="nx-showcase-summary">Configurable pipeline switches utilizing automated optimization engines to clear congestion vectors instantly.</p>
                </div>
              </div>
            </div>

            <!-- Horizontal Element Block 3: Modular Unit C -->
            <div class="nx-horizontal-panel">
              <div class="nx-showcase-card">
                <div class="nx-showcase-image-mock">
                  <div class="nx-mock-circuit-lines"></div>
                  <span class="nx-mock-overlay-code">MOD_CORE_GAMMA</span>
                </div>
                <div class="nx-showcase-meta">
                  <span class="nx-showcase-category">VISUAL ANALYTICS</span>
                  <h3 class="nx-showcase-name">Unified Command Board</h3>
                  <p class="nx-showcase-summary">Comprehensive interface panels visually tracking structural microservices across geographic regions.</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </section>


      <!-- SECTION 4: Scaled Metrics Visualization Board Grid -->
      <section id="analytics" class="nx-analytics-section">
        <div class="nx-container">
          <div class="nx-center-header">
            <div class="nx-section-index">[ 03 / METRICS ]</div>
            <h2 class="nx-section-title">Verified Structural Performance Diagnostics</h2>
          </div>

          <div class="nx-grid-matrix-4">
            
            <div class="nx-diagnostic-node">
              <div class="nx-diagnostic-value" data-target="240">240<span class="nx-value-unit">ms</span></div>
              <div class="nx-diagnostic-label">Global Execution Latency Reductions</div>
              <p class="nx-diagnostic-detail">Evaluated against cloud-native load balancing environments handling concurrent packet exchanges.</p>
            </div>

            <div class="nx-diagnostic-node highlighted-node">
              <div class="nx-diagnostic-value" data-target="12">12<span class="nx-value-unit">x</span></div>
              <div class="nx-diagnostic-label">Throughput Optimization Gain</div>
              <p class="nx-diagnostic-detail">Observed when switching storage nodes over to localized asynchronous pipeline protocols.</p>
            </div>

            <div class="nx-diagnostic-node">
              <div class="nx-diagnostic-value" data-target="99">99<span class="nx-value-unit">%</span></div>
              <div class="nx-diagnostic-label">Hardware Thread Allocation</div>
              <p class="nx-diagnostic-detail">Continuous optimization across bare-metal environments prevents memory stagnation bugs.</p>
            </div>

            <div class="nx-diagnostic-node">
              <div class="nx-diagnostic-value" data-target="0">0.00<span class="nx-value-unit">ms</span></div>
              <div class="nx-diagnostic-label">Mean Core System Recovery Delay</div>
              <p class="nx-diagnostic-detail">Automated localized recovery mechanisms resolve state changes without dropping connections.</p>
            </div>

          </div>
        </div>
      </section>


      <!-- SECTION 5: Enterprise Portal / Dynamic Masking Scale Footer -->
      <footer id="contact" class="nx-footer-system">
        <div class="nx-container nx-footer-cta-container">
          <div class="nx-footer-mask-box">
            <h2 class="nx-footer-massive-title">TRANSFORM THE CORE</h2>
            <p class="nx-footer-lead">
              Coordinate architecture deployment blueprints with an expert systems technician. Let's maximize structural capacity.
            </p>
            <div class="nx-footer-action-row">
              <button class="nx-btn nx-btn-primary nx-btn-xl">Request Infrastructure Audit</button>
              <button class="nx-btn nx-btn-outline nx-btn-xl">Connect via Telemetry</button>
            </div>
          </div>
        </div>

        <div class="nx-container nx-footer-directory-wrapper">
          <div class="nx-footer-grid">
            <div class="nx-footer-brand-column">
              <div class="nx-brand">
                <div class="nx-brand-indicator"></div>
                <span class="nx-brand-firm">NEXIS</span><span class="nx-brand-division">CORE</span>
              </div>
              <p class="nx-brand-legal-desc">
                High-performance foundational software layers providing deterministic cloud computing infrastructures for critical enterprise systems.
              </p>
            </div>
            
            <div class="nx-footer-links-column">
              <span class="nx-links-header">Infrastructure</span>
              <a href="#" class="nx-footer-link">Compute Nodes</a>
              <a href="#" class="nx-footer-link">Data Mesh Arrays</a>
              <a href="#" class="nx-footer-link">MariaDB Connectors</a>
              <a href="#" class="nx-footer-link">Security Hardware</a>
            </div>

            <div class="nx-footer-links-column">
              <span class="nx-links-header">Architecture</span>
              <a href="#" class="nx-footer-link">Whitepapers</a>
              <a href="#" class="nx-footer-link">Core Benchmarks</a>
              <a href="#" class="nx-footer-link">System Status logs</a>
              <a href="#" class="nx-footer-link">Developer Core API</a>
            </div>

            <div class="nx-footer-links-column">
              <span class="nx-links-header">Corporate</span>
              <a href="#" class="nx-footer-link">Operations Directory</a>
              <a href="#" class="nx-footer-link">Cyber Security Standards</a>
              <a href="#" class="nx-footer-link">Partnership Ecosystem</a>
              <a href="#" class="nx-footer-link">Institutional Governance</a>
            </div>
          </div>

          <div class="nx-footer-bottom-bar">
            <div class="nx-copyright">&copy; 2026 NEXIS CORE AG. GLOBAL DISTRIBUTION RIGHTS REGISTERED.</div>
            <div class="nx-legal-policy-links">
              <a href="#" class="nx-policy-link">CRYPTOGRAPHIC STATEMENT</a>
              <a href="#" class="nx-policy-link">PRIVACY PIPELINE</a>
              <a href="#" class="nx-policy-link">TERMS OF COMPUTE</a>
            </div>
          </div>
        </div>
      </footer>

    </main>

    <!-- 
      ENTERPRISE PLATFORM STYLESHEET (1000+ Lines Design System Architecture Layout Engine)
    -->
    <style is:global>
      /* ---------------------------------------------------------------------
         SECTION 1: ARCHITECTURE DESIGN TOKENS & SYSTEM VARIABLES
         --------------------------------------------------------------------- */
      :root {
        /* Color System Tokens */
        --color-zinc-50: #fafafa;
        --color-zinc-100: #f4f4f5;
        --color-zinc-200: #e4e4e7;
        --color-zinc-300: #d4d4d8;
        --color-zinc-400: #a1a1aa;
        --color-zinc-500: #71717a;
        --color-zinc-600: #52525b;
        --color-zinc-700: #3f3f46;
        --color-zinc-800: #27272a;
        --color-zinc-900: #18181b;
        --color-zinc-950: #09090b;
        
        /* Brand Specific Custom Glass Tone Palette */
        --color-primary: #FFFE88; /* High Fidelity Accent Yellow */
        --color-primary-rgb: 255, 254, 136;
        --color-primary-dark: #e6e56c;
        --color-accent-dim: rgba(255, 254, 136, 0.15);
        
        /* Layout Grid Dimensions Matrices */
        --max-width-desktop: 1440px;
        --header-height: 80px;
        --border-radius-sm: 6px;
        --border-radius-md: 12px;
        --border-radius-lg: 24px;
        --border-radius-full: 9999px;
        
        /* Typography Scale Metric Engine */
        --font-sans: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
        
        /* Z-Index Stratification Map */
        --z-index-backdrop: -10;
        --z-index-base: 1;
        --z-index-sticky: 20;
        --z-index-header: 50;
        --z-index-overlay: 100;
        
        /* Hardware Acceleration Easing Presets */
        --ease-smooth-io: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-inertial: cubic-bezier(0.16, 1, 0.3, 1);
        --ease-circ: cubic-bezier(0, 0.55, 0.45, 1);
        
        /* Glassmorphic Alpha Composition Elements */
        --glass-bg: rgba(9, 9, 11, 0.45);
        --glass-bg-dense: rgba(24, 24, 27, 0.75);
        --glass-border: rgba(39, 39, 42, 0.4);
        --glass-border-light: rgba(255, 254, 136, 0.2);
        --glass-blur: 16px;
      }

      /* ---------------------------------------------------------------------
         SECTION 2: NATIVE NORMALIZATION CSS RESET
         --------------------------------------------------------------------- */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      .core-system-html {
        font-size: 16px;
        scroll-behavior: auto !important; /* Managed by Lenis Engine */
        background-color: var(--color-zinc-950);
        color: var(--color-zinc-50);
        text-size-adjust: 100%;
        -webkit-text-size-adjust: 100%;
        overflow-x: hidden;
      }

      .core-system-body {
        font-family: var(--font-sans);
        background-color: var(--color-zinc-950);
        color: var(--color-zinc-100);
        min-height: 100vh;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
        width: 100%;
      }

      /* Lenis Core Integration Standard Rules Override Layouts */
      html.lenis, html.lenis body {
        height: auto;
      }
      .lenis-smooth {
        scroll-behavior: auto !important;
      }
      .lenis-smooth [data-lenis-prevent] {
        scroll-navigation: contain;
      }
      .lenis-stopped {
        overflow: hidden;
      }
      .lenis-scrolling iframe {
        pointer-events: none;
      }

      /* ---------------------------------------------------------------------
         SECTION 3: CORE TYPOGRAPHY UTILITY SUBSYSTEM
         --------------------------------------------------------------------- */
      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-sans);
        color: var(--color-zinc-50);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
      }

      p {
        line-height: 1.6;
        color: var(--color-zinc-400);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      ul, ol {
        list-style: none;
      }

      img, svg, video {
        display: block;
        max-width: 100%;
        height: auto;
      }

      button, input, select, textarea {
        font-family: inherit;
        font-size: inherit;
        color: inherit;
        background: none;
        border: none;
        outline: none;
      }

      /* Custom Selection Engine Style */
      ::-webkit-selection {
        background-color: var(--color-primary);
        color: var(--color-zinc-950);
      }
      ::selection {
        background-color: var(--color-primary);
        color: var(--color-zinc-950);
      }

      /* Custom Scrollbar Map Configs for Non-supported Lenis Edge Environments */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--color-zinc-950);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--color-zinc-800);
        border-radius: var(--border-radius-full);
      }
      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-zinc-700);
      }

      /* ---------------------------------------------------------------------
         SECTION 4: FLEX & GRID STRUCTURAL LAYOUT ENGINE
         --------------------------------------------------------------------- */
      .nx-container {
        width: 100%;
        max-width: var(--max-width-desktop);
        margin-left: auto;
        margin-right: auto;
        padding-left: 24px;
        padding-right: 24px;
      }

      .nx-scroll-wrapper {
        position: relative;
        width: 100%;
        overflow: hidden;
      }

      .nx-grid-matrix-2 {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 32px;
      }

      .nx-grid-matrix-3 {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 32px;
      }

      .nx-grid-matrix-4 {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 24px;
      }

      /* ---------------------------------------------------------------------
         SECTION 5: ENTERPRISE UI BUTTONS & INTERACTIVE COMPONENT LAYOUTS
         --------------------------------------------------------------------- */
      .nx-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans);
        font-weight: 600;
        letter-spacing: -0.01em;
        border-radius: var(--border-radius-full);
        transition: all 0.3s var(--ease-smooth-io);
        cursor: pointer;
        white-space: nowrap;
        position: relative;
        overflow: hidden;
      }

      .nx-btn-sm {
        padding: 10px 20px;
        font-size: 0.8125rem;
      }

      .nx-btn-md {
        padding: 14px 28px;
        font-size: 0.9375rem;
      }

      .nx-btn-lg {
        padding: 18px 36px;
        font-size: 1rem;
      }

      .nx-btn-xl {
        padding: 22px 44px;
        font-size: 1.0625rem;
      }

      .nx-btn-primary {
        background-color: var(--color-zinc-50);
        color: var(--color-zinc-950);
      }
      .nx-btn-primary:hover {
        background-color: var(--color-primary);
        box-shadow: 0 0 30px rgba(255, 254, 136, 0.3);
        transform: translateY(-2px);
      }
      .nx-btn-primary:active {
        transform: translateY(0);
      }

      .nx-btn-secondary {
        background-color: var(--color-zinc-900);
        color: var(--color-zinc-200);
        border: 1px solid var(--color-zinc-800);
      }
      .nx-btn-secondary:hover {
        background-color: var(--color-zinc-800);
        border-color: var(--color-zinc-700);
        color: var(--color-zinc-50);
        transform: translateY(-2px);
      }

      .nx-btn-outline {
        background-color: transparent;
        color: var(--color-zinc-50);
        border: 1px solid var(--color-zinc-800);
      }
      .nx-btn-outline:hover {
        border-color: var(--color-primary);
        background-color: rgba(255, 254, 136, 0.02);
      }

      /* ---------------------------------------------------------------------
         SECTION 6: FIXED GLASSMORPHIC HEADER COMPONENT
         --------------------------------------------------------------------- */
      .nx-header {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: var(--header-height);
        background-color: var(--glass-bg);
        backdrop-filter: blur(var(--glass-blur));
        -webkit-backdrop-filter: blur(var(--glass-blur));
        border-b: 1px solid var(--glass-border);
        z-index: var(--z-index-header);
        transition: background-color 0.4s var(--ease-smooth-io);
        will-change: background-color;
      }

      .nx-header-container {
        max-width: var(--max-width-desktop);
        height: 100%;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nx-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.1875rem;
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .nx-brand-indicator {
        width: 8px;
        height: 8px;
        background-color: var(--color-primary);
        border-radius: var(--border-radius-full);
        box-shadow: 0 0 10px var(--color-primary);
      }

