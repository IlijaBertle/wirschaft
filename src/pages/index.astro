        const lenis = new Lenis({
          duration: 1.4,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // High fidelity log inertia
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1.05,
          touchMultiplier: 1.5,
          infinite: false,
        });

        // 2. Continuous Synchronization between Lenis Pipeline and GSAP ScrollTrigger
        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });

        gsap.ticker.lagSmoothing(0);
        gsap.registerPlugin(ScrollTrigger);

        // 3. Hero Component Structural Convergence Transitions
        const tlHero = gsap.timeline({
          scrollTrigger: {
            trigger: "#hero",
            start: "top top",
            end: "bottom top",
            scrub: true
          }
        });

        tlHero.to(".hero-fade-in", {
          y: -60,
          opacity: 0,
          stagger: 0.05,
          ease: "none"
        }, 0);

        tlHero.to(".hero-card-trigger", {
          scale: 0.90,
          opacity: 0.1,
          y: -100,
          borderColor: "rgba(255, 254, 136, 0)",
          ease: "none"
        }, 0);

        // 4. Split Screen Cards Grid Intersect Animation Arrays
        if (window.innerWidth > 1024) {
          const cards = document.querySelectorAll(".scroll-reveal-card");
          cards.forEach((card, idx) => {
            gsap.fromTo(card, 
              { y: 100, opacity: 0, scale: 0.96 },
              {
                y: 0,
                opacity: 1,
                scale: 1,
                duration: 0.6,
                ease: "power2.out",
                scrollTrigger: {
                  trigger: card,
                  start: "top 90%",
                  toggleActions: "play none none reverse"
                }
              }
            );
          });
        }

        // 5. Cinema Panoramic Horizontal Scroll Track Assembly
        const trackRail = document.querySelector(".nx-horizontal-track-rail");
        if (trackRail) {
          gsap.to(trackRail, {
            x: () => -(trackRail.scrollWidth - window.innerWidth + (window.innerWidth * 0.12)),
            ease: "none",
            scrollTrigger: {
              trigger: ".nx-horizontal-scroller-container",
              pin: true,
              scrub: 1,
              start: "top top",
              end: () => `+=${trackRail.scrollWidth}`,
              invalidateOnRefresh: true,
            }
          });

          // Horizontal Dynamic Index Loading Line Bar Progression
          gsap.fromTo(".nx-scroller-indicator-progress", 
            { scaleX: 0.05 },
            {
              scaleX: 1,
              ease: "none",
              scrollTrigger: {
                trigger: ".nx-horizontal-scroller-container",
                start: "top top",
                end: () => `+=${trackRail.scrollWidth}`,
                scrub: true
              }
            }
          );
        }

        // 6. Live Dashboard Numerical Rolling Counters Loop System
        const metricNodes = document.querySelectorAll(".nx-diagnostic-value");
        metricNodes.forEach(node => {
          const targetValue = parseFloat(node.getAttribute("data-target"));
          const unitSpan = node.querySelector(".nx-value-unit")?.outerHTML || "";
          
          let counterObj = { value: 0 };
          
          gsap.to(counterObj, {
            value: targetValue,
            duration: 2,
            ease: "power3.out",
            scrollTrigger: {
              trigger: node,
              start: "top 85%",
              toggleActions: "play none none none"
            },
            onUpdate: () => {
              if (Number.isInteger(targetValue)) {
                node.innerHTML = Math.floor(counterObj.value) + unitSpan;
              } else {
                node.innerHTML = counterObj.value.toFixed(2) + unitSpan;
              }
            }
          });
        });

        // 7. Footer Spatial Compression Scale Up Effect
        gsap.fromTo(".nx-footer-mask-box", 
          { scale: 0.92, opacity: 0.4 },
          {
            scale: 1,
            opacity: 1,
            ease: "power2.out",
            scrollTrigger: {
              trigger: "#contact",
              start: "top 80%",
              end: "top 20%",
              scrub: true
            }
          }
        );

      });
    </script>
  </body>
</html>